#!/usr/bin/env bash
# .githooks/pre-commit
# Commercial path guard + profile validation before every commit.
# Install with: make install-hooks

set -e

# ── Commercial Path Guard ────────────────────────────────────────────────
DENY='^(builds/|data/icons/generated/|.*\.streamDeckProfile$|profiles/[^/]+/private/|profiles/[^/]+-colored/|profiles/[^/]+-commercial/|originals/|data/shortcuts/.*\.paid\.json$)'
STAGED=$(git diff --cached --name-only --diff-filter=ACM)

if echo "$STAGED" | grep -qE "$DENY"; then
  echo "ERROR: Commercial catalog paths cannot be committed to the public engine repo."
  echo ""
  echo "Offending files:"
  echo "$STAGED" | grep -E "$DENY" | sed 's/^/  - /'
  echo ""
  echo "Commit these to thisis-romar/stream-deck-catalog instead."
  exit 1
fi

# ── Profile Validation (non-blocking) ───────────────────────────────────
if echo "$STAGED" | grep -qE '^profiles/'; then
  node src/index.js validate profiles/ 2>/dev/null || true
fi
