#!/usr/bin/env bash
# .githooks/pre-push
# IP protection checks + version consistency + CHANGELOG freshness before push.
# Install with: make install-hooks

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

FAIL=0

# ── IP Protection Checks ────────────────────────────────────────────────

echo "[pre-push] Running IP protection checks..."

# LICENSE file presence and FSL content
if [ ! -f "LICENSE" ]; then
    echo "ERROR: LICENSE file is missing"
    FAIL=1
elif ! grep -q "Functional Source License" LICENSE; then
    echo "ERROR: LICENSE file does not contain Functional Source License text"
    FAIL=1
fi

# NOTICE file presence
if [ ! -f "NOTICE" ]; then
    echo "ERROR: NOTICE file is missing"
    FAIL=1
fi

if [ "$FAIL" -ne 0 ]; then
    echo "[pre-push] IP protection checks FAILED. Push blocked."
    exit 1
fi

echo "[pre-push] IP protection checks passed."

# ── Version Consistency ──────────────────────────────────────────────────

PKG_VERSION=$(node -p "require('./package.json').version" 2>/dev/null || echo "")

if [ -n "$PKG_VERSION" ] && [ -f "CHANGELOG.md" ]; then
    if ! grep -q "\[$PKG_VERSION\]" CHANGELOG.md; then
        echo "[pre-push] WARNING: CHANGELOG.md has no entry for v$PKG_VERSION"
        echo "           Add a ## [$PKG_VERSION] section before the next release."
    fi
fi

echo "[pre-push] All checks passed."
