{
  "name": "opendeck-factory",
  "version": "2.2.0",
  "type": "module",
  "description": "Open-source Stream Deck profile editor engine",
  "main": "src/index.js",
  "license": "FSL-1.1-ALv2",
  "author": "Romar Johnson <thisis.romar+github@gmail.com> (https://github.com/thisis-romar)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thisis-romar/opendeck-factory.git"
  },
  "homepage": "https://github.com/thisis-romar/opendeck-factory#readme",
  "bugs": {
    "url": "https://github.com/thisis-romar/opendeck-factory/issues"
  },
  "scripts": {
    "extract": "node src/index.js extract",
    "pack": "node src/index.js pack",
    "validate": "node src/index.js validate",
    "list": "node src/index.js list",
    "views": "node scripts/gh-create-views.mjs && node scripts/gh-fix-roadmap-view.mjs",
    "views:headed": "node scripts/gh-create-views.mjs --headed && node scripts/gh-fix-roadmap-view.mjs",
    "views:dry": "node scripts/gh-create-views.mjs --dry-run",
    "views:fix": "node scripts/gh-create-views.mjs --reapply --headed && node scripts/gh-fix-roadmap-view.mjs",
    "dates:backfill": "node scripts/gh-set-milestone-dates.mjs",
    "dates:dry": "node scripts/gh-set-milestone-dates.mjs --dry-run",
    "workflows:toggle": "node scripts/gh-toggle-workflows.mjs --headed",
    "epics:dry": "node scripts/gh-link-subissues.mjs --dry-run",
    "epics:link": "node scripts/gh-link-subissues.mjs",
    "insights:probe": "node scripts/gh-create-insights.mjs --probe",
    "insights": "node scripts/gh-create-insights.mjs",
    "sprint:dry": "node scripts/gh-set-sprint.mjs --dry-run",
    "sprint:assign": "node scripts/gh-set-sprint.mjs",
    "triage": "node scripts/gh-triage-new-issue.mjs",
    "prepare": "make install-hooks",
    "brain:build": "echo 'Run /graphify knowledge/github in Claude Code to rebuild the graph'",
    "brain:query": "python -m graphify query"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "adm-zip": "^0.5.17"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.1.7",
    "playwright": "^1.59.1"
  }
}
